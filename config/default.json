{
  "$schema": "vajra-config-v1",
  "schemaVersion": 1,

  "routing": {
    "tier1Patterns": [
      { "pattern": "^/test\\b", "skill": "testing", "description": "Route test commands to testing skill" },
      { "pattern": "^/review\\b", "skill": "code-review", "description": "Route review commands to code-review" },
      { "pattern": "^/debug\\b", "skill": "systematic-debugging", "description": "Route debug to systematic-debugging" },
      { "pattern": "^/security\\b", "skill": "sentry-security-review", "description": "Route security to security review" },
      { "pattern": "^/spec\\b", "skill": "spec", "description": "Route spec to specification skill" },
      { "pattern": "^/plan\\b", "skill": "writing-plans", "description": "Route plan to writing-plans" },
      { "pattern": "^fix\\s+#\\d+", "skill": "systematic-debugging", "description": "Route 'fix #123' to debugging" },
      { "pattern": "^refactor\\b", "skill": "sentry-code-simplifier", "description": "Route refactor to simplifier" }
    ],
    "tier3Keywords": {
      "test": "testing",
      "review": "code-review",
      "debug": "systematic-debugging",
      "security": "sentry-security-review",
      "spec": "spec",
      "plan": "writing-plans",
      "deploy": "ci-cd",
      "monitor": "observability",
      "design": "frontend-design",
      "architecture": "hld",
      "database": "database-design",
      "api": "api-design",
      "performance": "performance-profiler",
      "accessibility": "audit",
      "brand": "brand",
      "slides": "slides",
      "diagram": "architecture-diagrams",
      "threat": "threat-modeling",
      "compliance": "compliance-checklist",
      "release": "release-engineering"
    },
    "regexEngine": "re2",
    "regexMaxLength": 1000,
    "regexTimeoutMs": 100
  },

  "campaigns": {
    "stateDir": "~/.claude/vajra/campaigns",
    "dbPath": "~/.claude/vajra/vajra.db",
    "maxCheckpoints": 20,
    "autoCheckpointInterval": 5
  },

  "memory": {
    "indexMaxLines": 200,
    "indexPath": "~/.claude/vajra/memory/index.md",
    "topicsDir": "~/.claude/vajra/memory/topics",
    "archiveDir": "~/.claude/vajra/memory/archive",
    "dreamConsolidation": {
      "enabled": true,
      "autoTriggerOnIndexOverflow": true
    }
  },

  "cost": {
    "alertThreshold": null,
    "currency": "USD",
    "trackPerOperation": true,
    "ratesPer1MTokens": {
      "opus-input": 15.0,
      "opus-output": 75.0,
      "sonnet-input": 3.0,
      "sonnet-output": 15.0,
      "haiku-input": 0.25,
      "haiku-output": 1.25
    }
  },

  "security": {
    "encryption": {
      "enabled": true,
      "algorithm": "aes-256-gcm",
      "scope": ["security-reports", "campaign-state"]
    },
    "filePermissions": "0600",
    "hmacAlgorithm": "sha256",
    "sanitization": {
      "stripPatterns": [
        "ignore previous instructions",
        "ignore all previous",
        "you are now",
        "system prompt",
        "\\[INST\\]",
        "\\[/INST\\]",
        "<\\|im_start\\|>",
        "<\\|im_end\\|>",
        "Human:",
        "Assistant:"
      ],
      "wrapInTags": true,
      "tagName": "untrusted-data"
    }
  },

  "fleet": {
    "maxAgents": 6,
    "defaultToolAllowlist": ["Read", "Glob", "Grep", "Bash", "Write", "Edit"],
    "discoveryRelayDir": "~/.claude/vajra/relay"
  },

  "limits": {
    "toolCallsPerAgent": 100,
    "toolCallsLimitedAgent": 20,
    "loopDetectionThreshold": 5
  },

  "cortex": {
    "enabled": true,
    "agentsDir": "~/.claude/agents",
    "agentRouting": {
      "backend": { "agent": "bhima", "model": "opus", "skills": ["api-design", "database-design", "performance-profiler"] },
      "frontend": { "agent": "nakula", "model": "opus", "skills": ["frontend-design", "ui-styling", "react-best-practices"] },
      "security": { "agent": "bhishma", "model": "opus", "skills": ["threat-modeling", "sentry-security-review", "sentry-find-bugs"] },
      "redteam": { "agent": "duryodhana", "model": "opus", "skills": ["sentry-security-review", "entry-point-analyzer"] },
      "pentest": { "agent": "shakuni", "model": "sonnet", "skills": ["sentry-security-review", "sentry-gha-security-review"] },
      "testing": { "agent": "vidura", "model": "sonnet", "skills": ["testing", "property-based-testing", "webapp-testing"] },
      "devops": { "agent": "hanuman", "model": "sonnet", "skills": ["ci-cd", "observability", "release-engineering"] },
      "incident": { "agent": "ashwatthama", "model": "sonnet", "skills": ["incident-response", "systematic-debugging"] },
      "product": { "agent": "draupadi", "model": "opus", "skills": ["product-spec", "prd-to-issues", "brainstorming"] },
      "architecture": { "agent": "yudhishthira", "model": "opus", "skills": ["hld", "lld", "architecture-diagrams"] },
      "code": { "agent": "arjuna", "model": "opus", "skills": ["code-review", "sentry-code-simplifier", "improve-codebase-architecture"] },
      "data": { "agent": "sahadeva", "model": "opus", "skills": ["data-analysis", "backtest-validation", "database-design"] },
      "quant": { "agent": "karna", "model": "opus", "skills": ["data-analysis", "backtest-validation"] },
      "junior": { "agent": "abhimanyu", "model": "sonnet", "skills": ["testing", "docs-validator"] },
      "strategy": { "agent": "krishna", "model": "opus", "skills": ["spec", "research", "decision-journal"] },
      "program": { "agent": "dhrishtadyumna", "model": "sonnet", "skills": ["prd-to-issues", "writing-plans", "executing-plans"] }
    },
    "fleetCrews": {
      "security-audit": {
        "lead": "bhishma",
        "agents": ["duryodhana", "shakuni", "vidura"],
        "description": "Full security audit: threat model + red team + pentest + QA validation"
      },
      "feature-build": {
        "lead": "arjuna",
        "agents": ["bhima", "nakula", "vidura"],
        "description": "Full-stack feature: principal leads, backend + frontend + QA in parallel"
      },
      "incident-response": {
        "lead": "ashwatthama",
        "agents": ["hanuman", "bhima"],
        "description": "Incident triage: SRE lead + DevOps + backend debug"
      },
      "architecture-review": {
        "lead": "yudhishthira",
        "agents": ["arjuna", "bhishma", "draupadi"],
        "description": "Architecture review: CTO leads, code + security + product perspectives"
      }
    }
  }
}
